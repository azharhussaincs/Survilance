<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.*?>
<StackPane xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.cms.ui.controller.LoginController"
           fx:id="rootPane"
           styleClass="login-root"
           stylesheets="@../css/dark-theme.css">

    <!-- Background gradient overlay -->
    <VBox alignment="CENTER" styleClass="login-bg-overlay">

        <!-- Logo area -->
        <VBox alignment="CENTER" spacing="4" VBox.vgrow="ALWAYS">
            <Label text="🎥" styleClass="app-logo-icon"/>
            <Label text="CMS" styleClass="app-logo-text"/>
            <Label text="Camera Management System" styleClass="app-logo-subtitle"/>
        </VBox>

        <!-- Login Card -->
        <VBox fx:id="loginCard" styleClass="login-card" spacing="0" alignment="CENTER">

            <VBox styleClass="login-card-header" alignment="CENTER" spacing="6">
                <Label text="Sign In" styleClass="login-title"/>
                <Label text="Enter your credentials to continue" styleClass="login-subtitle"/>
            </VBox>

            <VBox styleClass="login-card-body" spacing="16">

                <!-- Username -->
                <VBox spacing="6">
                    <Label text="Username" styleClass="field-label"/>
                    <HBox styleClass="input-wrapper" alignment="CENTER_LEFT">
                        <Label text="👤" styleClass="input-icon"/>
                        <TextField fx:id="usernameField" promptText="Enter username"
                                   styleClass="cms-textfield" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="Password" styleClass="field-label"/>
                    <HBox styleClass="input-wrapper" alignment="CENTER_LEFT">
                        <Label text="🔒" styleClass="input-icon"/>
                        <PasswordField fx:id="passwordField" promptText="Enter password"
                                       styleClass="cms-textfield" HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="passwordVisible" promptText="Enter password"
                                   styleClass="cms-textfield" HBox.hgrow="ALWAYS"
                                   visible="false" managed="false"/>
                        <Button fx:id="togglePasswordBtn" text="👁" styleClass="icon-button"
                                onAction="#togglePasswordVisibility"/>
                    </HBox>
                </VBox>

                <!-- Error label -->
                <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"/>

                <!-- Loading -->
                <HBox fx:id="loadingPane" alignment="CENTER" spacing="8">
                    <ProgressIndicator fx:id="loadingIndicator" maxWidth="20" maxHeight="20"/>
                    <Label text="Authenticating..." styleClass="loading-text"/>
                </HBox>

                <!-- Login Button -->
                <Button fx:id="loginButton" text="SIGN IN" styleClass="primary-button"
                        maxWidth="Infinity" onAction="#handleLogin"/>

            </VBox>

        </VBox>

        <!-- Footer -->
        <VBox alignment="CENTER" spacing="4" styleClass="login-footer">
            <Label text="Authorized personnel only. Unauthorized access is prohibited." styleClass="footer-warning"/>
            <HBox alignment="CENTER" spacing="8">
                <Label text="CMS Security Solutions" styleClass="footer-text"/>
                <Label text="•" styleClass="footer-text"/>
                <Label fx:id="versionLabel" styleClass="footer-text"/>
            </HBox>
        </VBox>

    </VBox>
</StackPane>
